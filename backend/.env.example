PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/acadify
JWT_SECRET=your_jwt_secret_key_change_in_production
COOKIE_SECRET=your_cookie_secret_key_change_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development
# Email & Registration Configuration
RESEND_API_KEY=your_resend_api_key_for_email
# ✅ CRITICAL: ALLOWED_EMAIL_DOMAIN controls student registration & login
# Students MUST have email matching this domain (@stvincentngp.edu.in)
# Teachers and admins can use any email domain
# Update this to match your institution's email domain
ALLOWED_EMAIL_DOMAIN=stvincentngp.edu.in
APP_URL=http://localhost:8080
